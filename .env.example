# Copy this file to ".env" and fill in your values.

# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
# If left blank, the app still runs but AI features return a friendly "configure your key" message.
GEMINI_API_KEY=

# Gemini model to use. Pick one your API key has quota for (see Google AI Studio).
# gemini-3.1-flash-lite and gemini-2.5-flash-lite are fast, cheap, and have generous free limits.
GEMINI_MODEL=gemini-2.5-flash-lite

# Port the server listens on
PORT=3000

# ─── Turso (cloud SQLite) ────────────────────────────────────────────────────
# Leave BOTH blank to use a local file database (./data/stride.db) for development.
# For production (Vercel), create a DB at https://app.turso.tech and paste:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Firebase Auth (OPTIONAL) ────────────────────────────────────────────────
# Leave all of this blank to run in DEMO MODE (no login, single shared user).
# To enable real accounts + Google sign-in, configure BOTH sides:
#
#  1. Frontend (browser): paste your Firebase *web* config into
#     frontend/assets/firebase-config.js
#
#  2. Backend (this server) — provide a *service account* one of two ways:
#     a) Put the downloaded service-account JSON at the project root as
#        serviceAccountKey.json  (simplest), OR
#     b) Fill in the three vars below (from that same JSON file).
#
# Firebase Console → Project settings → Service accounts → Generate new private key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the quotes and the literal \n sequences from the JSON's private_key.
FIREBASE_PRIVATE_KEY=

<script>
        document.addEventListener('DOMContentLoaded', () => {
            const focusToggle = document.getElementById('focusToggle');
            const sideNav = document.querySelector('nav');
            const topBar = document.querySelector('header');
            let isFocusMode = false;

            focusToggle.addEventListener('click', () => {
                isFocusMode = !isFocusMode;
                
                if (isFocusMode) {
                    sideNav.classList.add('focus-mode-active');
                    topBar.classList.add('focus-mode-active');
                    focusToggle.innerHTML = '<span class="material-symbols-outlined text-[20px]">close</span> Exit Focus Mode';
                    focusToggle.classList.replace('bg-primary', 'bg-surface-container-highest');
                    focusToggle.classList.replace('text-on-primary', 'text-on-surface');
                } else {
                    sideNav.classList.remove('focus-mode-active');
                    topBar.classList.remove('focus-mode-active');
                    focusToggle.innerHTML = '<span class="material-symbols-outlined text-[20px]">center_focus_strong</span> Enter Focus Mode';
                    focusToggle.classList.replace('bg-surface-container-highest', 'bg-primary');
                    focusToggle.classList.replace('text-on-surface', 'text-on-primary');
                }
            });

            // Micro-interaction for upload zone
            const uploadZone = document.querySelector('.glass-card.border-dashed');
            uploadZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadZone.classList.add('bg-primary-container/20');
            });
            uploadZone.addEventListener('dragleave', () => {
                uploadZone.classList.remove('bg-primary-container/20');
            });
            uploadZone.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadZone.classList.remove('bg-primary-container/20');
                alert('File uploaded! Analyzing your assignment brief...');
            });
        });
    </script>

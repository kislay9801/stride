<script>
        // Simple micro-interaction for the capacity ring
        window.addEventListener('DOMContentLoaded', () => {
            const ring = document.querySelector('.capacity-ring');
            if (ring) {
                // Initial state
                ring.style.strokeDashoffset = '552.92';
                // Animate to target (72% fill means 28% offset)
                setTimeout(() => {
                    ring.style.strokeDashoffset = '154.81'; // 552.92 * (1 - 0.72)
                }, 300);
            }
        });
